// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus{
  ACTIVE
  DISABLED
}

enum Role {
  USER
  ADMIN
}

enum Currency {
  VND
  USD
}

enum WalletStatus {
  ACTIVE
  DISABLED
}

enum TxKind {
  TRANSFER
  ADJUSTMENT
  TOPUP
  PAYMENT
  REFUND
}

enum TxStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
}

enum EntryType {
  DEBIT
  CREDIT
}

enum IdemStatus {
  IN_PROGRESS
  SUCCEEDED
  FAILED
}

enum PaymentStatus {
  CREATED
  HELD
  CAPTURED
  CANCELED
  REFUNDED
  FAILED
}

enum PaymentDirection {
  DEBIT
  CREDIT
}

enum HoldStatus {
  ACTIVE
  RELEASED
  CAPTURED
  EXPIRED
}

enum OutboxStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
}

enum AuditActorType {
  USER
  ADMIN
  SYSTEM
}

model User{
  id String @id @default(cuid())
  email String @unique
  passwordHash String
  status UserStatus @default(ACTIVE)
  role Role @default(USER)
  wallets Wallet[]
  payments Payment[]
  
  refreshTokens RefreshToken[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RefreshToken{
  id String @id @default(cuid())
  userId String
  tokenHash String
  revokedAt DateTime?
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

model FileObject{
  id String @id @default(cuid())
  bucket String
  objectKey String @unique
  mimeType String
  size Int
  createdBy String?
  createdAt DateTime @default(now())
}

model Wallet {
  id               String       @id @default(cuid())
  userId           String
  currency         Currency
  status           WalletStatus @default(ACTIVE)

  availableBalance BigInt       @default(0)
  lockedBalance    BigInt       @default(0)

  entries          LedgerEntry[]
  payments          Payment[]
  holdRecords       HoldRecord[]

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, currency])
  @@index([userId])
}

model LedgerTransaction {
  id        String    @id @default(cuid())
  kind      TxKind
  status    TxStatus
  currency  Currency
  amount    BigInt
  reference String?
  createdBy String?
  payments Payment[]

  entries   LedgerEntry[]
  createdAt DateTime  @default(now())
  @@unique([createdAt, id])
  @@index([createdAt, id])
}

model LedgerEntry {
  id        String            @id @default(cuid())
  txId      String
  walletId  String
  type      EntryType
  amount    BigInt
  currency  Currency

  tx        LedgerTransaction @relation(fields: [txId], references: [id], onDelete: Cascade)
  wallet    Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)

  createdAt DateTime          @default(now())

  @@index([walletId, createdAt])
  @@index([txId])
  @@index([currency, walletId, type])
}

model IdempotencyKey {
  key         String     @id
  scope       String
  status      IdemStatus @default(IN_PROGRESS)
  requestHash String?
  response    Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([scope, createdAt])
}

model Payment {
  id             String            @id @default(cuid())
  userId         String
  walletId       String
  currency       Currency
  amount         BigInt
  status         PaymentStatus     @default(CREATED)
  direction      PaymentDirection  @default(DEBIT)
  holdRecord     HoldRecord?
  merchantRef    String?
  externalRef    String?
  description    String?
  ledgerTxId     String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet         Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
  ledgerTx       LedgerTransaction? @relation(fields: [ledgerTxId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([walletId, createdAt])
  @@index([status, createdAt])
}

model HoldRecord {
  id           String      @id @default(cuid())
  paymentId    String      @unique
  walletId     String
  currency     Currency
  amount       BigInt
  status       HoldStatus  @default(ACTIVE)
  expiresAt    DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  payment      Payment     @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  wallet       Wallet      @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, status])
  @@index([status, expiresAt])
}

model OutboxEvent {
  id            String       @id @default(cuid())
  aggregateType String
  aggregateId   String
  eventType     String
  payload       Json
  status        OutboxStatus @default(PENDING)
  attempts      Int          @default(0)
  availableAt   DateTime     @default(now())
  publishedAt   DateTime?
  lastError     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status, availableAt])
  @@index([aggregateType, aggregateId])
  @@index([eventType, createdAt])
}

model AuditLog {
  id         String         @id @default(cuid())
  actorType  AuditActorType
  actorId    String?
  action     String
  entityType String
  entityId   String
  before     Json?
  after      Json?
  metadata   Json?
  traceId    String?
  createdAt  DateTime       @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([traceId])
}